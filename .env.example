# Copy this file to .env before starting the bot. Never commit .env.
# Dry-run needs no exchange credentials. Add read/trade API credentials ONLY if
# your exchange requires them for market data. Keep withdrawal permission OFF.
EXCHANGE_NAME=binance
EXCHANGE_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=

# Telegram is off by default. Set TELEGRAM_ENABLED=true only after filling both
# values. Create a bot with BotFather and use your numeric chat ID.
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Docker publishes the API/UI to 127.0.0.1 on the VPS by default. Change these
# before starting and access it through an SSH tunnel or authenticated proxy.
API_USERNAME=freqtrade
API_PASSWORD=CHANGE_THIS_TO_A_LONG_UNIQUE_PASSWORD
API_JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING_AT_LEAST_32_CHARACTERS_LONG
